# ─────────────────────────────────────────────────────────────────────────────
# To-Do App — Environment Variables
#
# Copy this file to .env and fill in the values before running docker-compose.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────

# Root password for the MySQL container (used by the healthcheck)
DB_ROOT_PASSWORD=change_me_root_password

# Application database name (defaults to "todoapp" if not set)
DB_NAME=todoapp

# Application database user and password (used by the Spring Boot API)
DB_USER=todoapp_user
DB_PASSWORD=change_me_db_password

# Host port to expose MySQL on (defaults to 3306)
# Set to an empty string or remove to avoid exposing MySQL outside Docker
DB_PORT=3306


# ── JWT ───────────────────────────────────────────────────────────────────────

# Secret key used to sign JWTs — must be at least 256 bits (32 characters).
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars


# ── Mail ──────────────────────────────────────────────────────────────────────

# SMTP server hostname (e.g. smtp.sendgrid.net, smtp.mailgun.org)
MAIL_HOST=smtp.example.com

# SMTP port (25 = plain, 465 = SSL, 587 = STARTTLS)
MAIL_PORT=587

# SMTP authentication credentials
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=change_me_smtp_password


# ── API ───────────────────────────────────────────────────────────────────────

# Host port to expose the Spring Boot API on (defaults to 8080)
API_PORT=8080

# Spring profile to activate (prod | dev)
SPRING_PROFILES_ACTIVE=prod
